# Sapienoids Analytics Portal — Environment Variables
# Copy this file to .env and fill in your keys.
# Get free keys at: https://aistudio.google.com/app/apikey
# .env is listed in .gitignore — it will NEVER be committed or shared.

# ── Gemini API Keys (Dual-Key Sentinel) ──────────────────────────────────────
GEMINI_KEY_PRIMARY=your_primary_key_here
GEMINI_KEY_BACKUP=your_backup_key_here

# ── Gemini Model (optional — defaults to gemini-1.5-flash) ───────────────────
# Other options: gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# ── Quota Settings (optional — change only if you have a paid plan) ──────────
GEMINI_DAILY_LIMIT=500
GEMINI_FAILOVER_PCT=0.80
